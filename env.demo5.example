# Nombre de la base de datos SQL Server del entorno
DATABASE=

# Usuario con permisos de escritura en la base de datos
USER_DB=

# Contraseña del usuario de la base de datos
PASSWORD_DB=

# Host o FQDN del servidor SQL Server (ej: miservidor.database.windows.net)
SERVER_DB=

# URL base de la aplicación DexServer (ej: https://demo5.dexmanager.com)
BASE_URL_DEX=

# automation-api (reporter de TestRail y creación de players headless)

# URL donde corre la automation-api localmente
AUTOMATION_API_URL=http://localhost:3050

# Token de autenticación para la automation-api
AUTOMATION_API_TOKEN=

# Clave que identifica la base de datos en la automation-api (ej: demo5)
AUTOMATION_API_DB_KEY=
